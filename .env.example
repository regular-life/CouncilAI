# CouncilAI Environment Secrets Configuration
# -------------------------------------------------------------
# Sensitive API keys and credentials.
# Note: For general non-sensitive settings, use config.yaml.
# You can generate a complete .env with a secure random JWT secret
# by running the ./setup.sh script at the root directory.

# ── API Keys ──────────────────────────────────────────────────
# Add keys for the LLM providers you plan to use:
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=

# ── HuggingFace Token ─────────────────────────────────────────
# Required only for gated local models (e.g., Llama 3) in vLLM:
HF_TOKEN=

# ── JWT Security Secret ───────────────────────────────────────
# Generated securely during setup. DO NOT commit this file to Git.
JWT_SECRET=

# ── Testing / Development ─────────────────────────────────────
# Set to true to mock external LLM calls (useful for offline dev):
MOCK_LLM=false