# PadhAI-Dost Environment Configuration
# Copy this file to .env and fill in your values.

# ── API Keys ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string

# ── LLM Council Models (via OpenRouter) ──────────────────────────────
COUNCIL_MODEL_1=arcee-ai/trinity-large-preview:free
COUNCIL_MODEL_2=stepfun/step-3.5-flash:free
COUNCIL_MODEL_3=nvidia/nemotron-3-nano-30b-a3b:free

CHAIRMAN_MODEL=gemini-3-flash-preview

# ── Embedding ────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Timeouts ─────────────────────────────────────────────────────────
STAGE_TIMEOUT=30s
LLM_TIMEOUT=120s